{
  "name": "scry-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:release": "expo prebuild --platform android --no-install && cd android && gradlew.bat assembleRelease --stacktrace",
    "build:aab": "expo prebuild --platform android --no-install && cd android && gradlew.bat bundleRelease --stacktrace",
    "clean:android": "powershell -Command \"Remove-Item android\\app\\build,android\\build,android\\.gradle,android\\app\\.cxx -Recurse -Force -ErrorAction SilentlyContinue; Write-Host 'Android cleaned'\"",
    "release": "gh release create v1.0.0 --title \"Scry v1.0.0\" --notes \"Scan. Extract. Understand. AI-powered document scanner.\" \"android\\app\\build\\outputs\\apk\\release\\app-release.apk#Scry.apk\""
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.186",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.96.1",
    "ai": "^6.0.184",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-print": "^14.0.0",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "^55.0.18",
    "phosphor-react-native": "^3.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
